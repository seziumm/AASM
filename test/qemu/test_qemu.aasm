# test_qemu.aasm — QEMU virt RV32, stampa "Hello, AASM!\n"
#
# Run:
#   make -C test/qemu clean && make -C test/qemu

.CODE

&MAIN
    LUI  X1, 65536         # X1 = 0x10000000 (UART base)

    # init ns16550a
    ADDI X7, X0, 0
    SB   X7, 1(X1)         # IER = 0

    ADDI X7, X0, 3
    SB   X7, 3(X1)         # LCR = 0x03 (8N1)

    ADDI X7, X0, 1
    SB   X7, 2(X1)         # FCR = 0x01

    # stringa via AUIPC + ADDI (no label ref necessario)
    AUIPC X6, 0            # X6 = PC di questa istruzione
    ADDI  X6, X6, 32       # X6 += 32 -> punta a &STR

&LOOP
    LB   X8, 0(X6)
    BEQ  X8, X0, @HALT
    SB   X8, 0(X1)
    ADDI X6, X6, 1
    JAL  X0, @LOOP

&HALT
    JAL  X0, @HALT

.DATA

&STR
.BYTE 72
.BYTE 101
.BYTE 108
.BYTE 108
.BYTE 111
.BYTE 44
.BYTE 32
.BYTE 65
.BYTE 65
.BYTE 83
.BYTE 77
.BYTE 33
.BYTE 10
.BYTE 0
