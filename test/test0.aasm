.BYTE 4
.BYTE 4
.BYTE 4
.BYTE 4
.BYTE 4
.CODE
.BYTE 4
.BYTE 4

&MAIN
    # X1 = contatore (1..10)
    # X2 = somma accumulata
    # X3 = limite (10)

    ADDI X1, X0, 1       # I-type: contatore = 1
    ADDI X2, X0, 0       # I-type: somma = 0
    ADDI X3, X0, 10      # I-type: limite = 10

&LOOP
    ADD  X2, X2, X1      # R-type: somma += contatore
    ADDI X1, X1, 1       # I-type: contatore++
    # non possiamo fare branch (B-type) ne jump (J-type)
    # quindi il loop e' impossibile con sole I/R-type

.BYTE 4
.DATA
.BYTE 4
