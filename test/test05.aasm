# test05.aasm
# SLT, SLTU, SLTI, SLTIU

.CODE
&MAIN
    ADDI X1, X0, 5
    ADDI X2, X0, 10
    SLT  X3, X1, X2      # X3 = 1  (5 < 10)
    SLT  X4, X2, X1      # X4 = 0  (10 < 5 is false)
    SLTU X5, X1, X2      # X5 = 1
    SLTI X6, X1, 6       # X6 = 1  (5 < 6)
    SLTI X7, X1, 5       # X7 = 0  (5 < 5 is false)
    SLTIU X8, X1, 6      # X8 = 1
