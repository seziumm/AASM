# test07.aasm
# Store instructions: SB, SH, SW

.CODE
&MAIN
    ADDI X1, X0, 0       # base address = 0
    ADDI X2, X0, 42      # value to store
    SW   X2, 0(X1)       # store word  at addr 0
    SH   X2, 4(X1)       # store half  at addr 4
    SB   X2, 6(X1)       # store byte  at addr 6
    ADDI X3, X0, 255
    SB   X3, 7(X1)       # store byte at addr 7
    SW   X3, 8(X1)       # store word at addr 8
