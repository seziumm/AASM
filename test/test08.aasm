# test08.aasm
# Branch instructions: BEQ, BNE, BLT, BGE, BLTU, BGEU

.CODE
&MAIN
    ADDI X1, X0, 5
    ADDI X2, X0, 5
    BEQ  X1, X2, @EQUAL

&NOTEQ
    ADDI X3, X0, 0
    JAL  X0, @END

&EQUAL
    ADDI X3, X0, 1
    BNE  X1, X2, @END    # won't branch (they are equal)
    BGE  X1, X2, @END    # will branch  (5 >= 5)

&END
    ADDI X0, X0, 0       # NOP
