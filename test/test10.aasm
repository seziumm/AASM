# test10.aasm
# J-type and JALR: subroutine call and return pattern

.CODE
&MAIN
    ADDI X1, X0, 0
    JAL  X1, @FUNC       # call FUNC, return addr in X1
    ADDI X2, X0, 99      # executed after return
    JAL  X0, @END        # halt

&FUNC
    ADDI X3, X0, 42      # body of FUNC
    JALR X0, X1, 0       # return

&END
    ADDI X0, X0, 0       # NOP
