# test15.aasm
# Fibonacci: compute fib(10) iteratively
# X1 = a (fib n-2), X2 = b (fib n-1), X3 = counter, X4 = tmp

.CODE
&MAIN
    ADDI X1, X0, 0       # a = 0  (fib 0)
    ADDI X2, X0, 1       # b = 1  (fib 1)
    ADDI X3, X0, 10      # counter = 10
    ADDI X5, X0, 1       # step

&LOOP
    ADD  X4, X1, X2      # tmp = a + b
    ADD  X1, X0, X2      # a = b
    ADD  X2, X0, X4      # b = tmp
    SUB  X3, X3, X5      # counter--
    BNE  X3, X0, @LOOP   # repeat until 0

&END
    JAL  X0, @END        # X2 holds fib(10) = 55
