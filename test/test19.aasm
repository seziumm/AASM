# test19.aasm
# ANDI, ORI, XORI + register variants

.CODE
&MAIN
    ADDI X1, X0, 255     # X1 = 0xFF
    ANDI X2, X1, 15      # X2 = 0x0F  (low nibble)
    ORI  X3, X0, 240     # X3 = 0xF0
    XORI X4, X1, 255     # X4 = 0x00  (all bits flipped)
    AND  X5, X1, X3      # X5 = 0xF0
    OR   X6, X2, X3      # X6 = 0xFF
    XOR  X7, X1, X1      # X7 = 0x00  (self-xor)
    XORI X8, X0, -1      # X8 = 0xFFFFFFFF (all ones)
