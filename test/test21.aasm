# test21.aasm
# Multiply X1 * X2 via repeated addition -> X3
# (for targets without M extension)

.CODE
&MAIN
    ADDI X1, X0, 6       # multiplicand
    ADDI X2, X0, 7       # multiplier
    ADDI X3, X0, 0       # result = 0
    ADDI X4, X0, 1       # step

&LOOP
    ADD  X3, X3, X1      # result += multiplicand
    SUB  X2, X2, X4      # multiplier--
    BNE  X2, X0, @LOOP   # repeat until 0

&END
    JAL  X0, @END        # X3 = 42
