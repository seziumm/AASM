# test22.aasm
# Negative immediates, ADDI sign extension, SRAI sign preservation

.CODE
&MAIN
    ADDI X1, X0, -1      # X1 = 0xFFFFFFFF
    ADDI X2, X0, -128    # X2 = 0xFFFFFF80
    ADDI X3, X0, -2048   # X3 = 0xFFFFF800 (min 12-bit imm)
    SRAI X4, X1, 4       # X4 = 0xFFFFFFFF (sign preserved)
    SRAI X5, X2, 3       # X5 = 0xFFFFFFF0
    SRLI X6, X1, 4       # X6 = 0x0FFFFFFF (zero-fill)
    SUB  X7, X0, X2      # X7 = +128
    ADD  X8, X1, X3      # X8 = -2049
