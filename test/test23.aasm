# test23.aasm
# Bubble sort on 5 words stored in memory starting at addr 0x100
# X1 = base, X2 = outer i, X3 = inner j, X4/X5 = tmp words

.CODE
&MAIN
    LUI  X1, 0           # base = 0x000 (word-aligned array)
    ADDI X1, X1, 512     # base = 512

    # store unsorted array: [5, 3, 8, 1, 4]
    ADDI X9, X0, 5
    SW   X9, 0(X1)
    ADDI X9, X0, 3
    SW   X9, 4(X1)
    ADDI X9, X0, 8
    SW   X9, 8(X1)
    ADDI X9, X0, 1
    SW   X9, 12(X1)
    ADDI X9, X0, 4
    SW   X9, 16(X1)

    ADDI X2, X0, 4       # outer = 4 passes

&OUTER
    ADDI X3, X0, 0       # inner j = 0
    ADDI X6, X0, 4       # limit = 4

&INNER
    SLL  X7, X3, X0      # offset_j = j * 4  (shift by 0 then add trick)
    ADDI X7, X3, 0       # X7 = j
    SLLI X7, X7, 2       # X7 = j * 4
    ADD  X8, X1, X7      # addr = base + j*4
    LW   X4, 0(X8)       # X4 = arr[j]
    LW   X5, 4(X8)       # X5 = arr[j+1]
    SLT  X10, X5, X4     # X10 = 1 if arr[j+1] < arr[j]
    BEQ  X10, X0, @SKIP  # no swap needed

    SW   X5, 0(X8)       # arr[j]   = arr[j+1]
    SW   X4, 4(X8)       # arr[j+1] = arr[j]

&SKIP
    ADDI X3, X3, 1       # j++
    BLT  X3, X6, @INNER  # if j < 4 continue inner

    ADDI X2, X2, -1      # outer--
    ADDI X11, X0, 1
    BGE  X2, X11, @OUTER # if outer >= 1 continue

&END
    JAL  X0, @END
