# test24.aasm
# Popcount: count the number of 1-bits in X1 -> X2
# Uses shift-and-mask loop

.CODE
&MAIN
    ADDI X1, X0, 0       # init: will be set below
    XORI X1, X0, -1      # X1 = 0xFFFFFFFF  (32 bits set)
    ADDI X2, X0, 0       # count = 0
    ADDI X3, X0, 32      # loop counter = 32
    ADDI X4, X0, 1       # mask = 1

&LOOP
    AND  X5, X1, X4      # X5 = X1 & 1
    ADD  X2, X2, X5      # count += lsb
    SRLI X1, X1, 1       # X1 >>= 1
    ADDI X3, X3, -1      # counter--
    BNE  X3, X0, @LOOP   # repeat 32 times

&END
    JAL  X0, @END        # X2 = 32
