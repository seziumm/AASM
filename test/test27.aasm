# test27.aasm
# Reverse 8 bytes in place at base address X1
# X2 = lo pointer, X3 = hi pointer, X4/X5 = tmp

.CODE
&MAIN
    ADDI X1, X0, 512     # base = 64

    # store [1,2,3,4,5,6,7,8]
    ADDI X9, X0, 1
    SB   X9, 0(X1)
    ADDI X9, X0, 2
    SB   X9, 1(X1)
    ADDI X9, X0, 3
    SB   X9, 2(X1)
    ADDI X9, X0, 4
    SB   X9, 3(X1)
    ADDI X9, X0, 5
    SB   X9, 4(X1)
    ADDI X9, X0, 6
    SB   X9, 5(X1)
    ADDI X9, X0, 7
    SB   X9, 6(X1)
    ADDI X9, X0, 8
    SB   X9, 7(X1)

    ADD  X2, X0, X1      # lo = base
    ADDI X3, X1, 7       # hi = base + 7

&LOOP
    BGE  X2, X3, @END    # while lo < hi
    LBU  X4, 0(X2)       # tmp_lo = *lo
    LBU  X5, 0(X3)       # tmp_hi = *hi
    SB   X5, 0(X2)       # *lo = tmp_hi
    SB   X4, 0(X3)       # *hi = tmp_lo
    ADDI X2, X2, 1       # lo++
    ADDI X3, X3, -1      # hi--
    JAL  X0, @LOOP

&END
    JAL  X0, @END
