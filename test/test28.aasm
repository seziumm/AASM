# test28.aasm
# Sum 8 words from memory -> X3 (checksum)
# X1 = base, X2 = counter, X3 = acc, X4 = tmp

.CODE
&MAIN
    ADDI X1, X0, 512     # base
    ADDI X2, X0, 8       # count = 8
    ADDI X3, X0, 0       # acc = 0
    ADDI X5, X0, 1       # step

    # store [10,20,30,40,50,60,70,80]
    ADDI X9, X0, 10
    SW   X9, 0(X1)
    ADDI X9, X0, 20
    SW   X9, 4(X1)
    ADDI X9, X0, 30
    SW   X9, 8(X1)
    ADDI X9, X0, 40
    SW   X9, 12(X1)
    ADDI X9, X0, 50
    SW   X9, 16(X1)
    ADDI X9, X0, 60
    SW   X9, 20(X1)
    ADDI X9, X0, 70
    SW   X9, 24(X1)
    ADDI X9, X0, 80
    SW   X9, 28(X1)

    ADD  X6, X0, X1      # ptr = base

&LOOP
    LW   X4, 0(X6)       # load word
    ADD  X3, X3, X4      # acc += word
    ADDI X6, X6, 4       # ptr += 4
    SUB  X2, X2, X5      # count--
    BNE  X2, X0, @LOOP

&END
    JAL  X0, @END        # X3 = 360
