# test29.aasm
# Find minimum of 6 words in memory -> X3
# X1 = base, X2 = counter, X3 = min, X4 = current

.CODE
&MAIN
    ADDI X1, X0, 512     # base

    # store [7, 2, 9, 1, 5, 4]
    ADDI X9, X0, 7
    SW   X9, 0(X1)
    ADDI X9, X0, 2
    SW   X9, 4(X1)
    ADDI X9, X0, 9
    SW   X9, 8(X1)
    ADDI X9, X0, 1
    SW   X9, 12(X1)
    ADDI X9, X0, 5
    SW   X9, 16(X1)
    ADDI X9, X0, 4
    SW   X9, 20(X1)

    LW   X3, 0(X1)       # min = arr[0]
    ADDI X2, X0, 5       # remaining = 5
    ADDI X6, X1, 4       # ptr = base + 4

&LOOP
    LW   X4, 0(X6)       # current = *ptr
    SLT  X5, X4, X3      # X5 = 1 if current < min
    BEQ  X5, X0, @SKIP   # no update
    ADD  X3, X0, X4      # min = current

&SKIP
    ADDI X6, X6, 4       # ptr++
    ADDI X2, X2, -1      # remaining--
    BNE  X2, X0, @LOOP

&END
    JAL  X0, @END        # X3 = 1
