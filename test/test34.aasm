# test34.aasm
# Pack four bytes [0xDE, 0xAD, 0xBE, 0xEF] into one 32-bit word -> X5
# Expected: 0xEFBEADDE (little-endian in register)

.CODE
&MAIN
    ADDI X1, X0, 0       # byte0 = 0xDE (222)
    ADDI X1, X0, -34     # 256-34=222 = 0xDE
    ADDI X2, X0, -83     # 0xAD = 173; use -83 trick: 256-83=173
    ADDI X3, X0, -66     # 0xBE = 190
    ADDI X4, X0, -17     # 0xEF = 239

    ANDI X1, X1, 255
    ANDI X2, X2, 255
    ANDI X3, X3, 255
    ANDI X4, X4, 255

    SLLI X2, X2, 8       # byte1 << 8
    SLLI X3, X3, 16      # byte2 << 16
    SLLI X4, X4, 24      # byte3 << 24 -- NOTE: immediate shift 24

    OR   X5, X1, X2
    OR   X5, X5, X3
    OR   X5, X5, X4

&END
    JAL  X0, @END        # X5 = 0xEFBEADDE
