# test35.aasm
# Unpack 0x12345678 into four bytes -> X1..X4

.CODE
&MAIN
    LUI  X10, 4660       # X10 = 0x12340000
    ADDI X10, X10, 0     # keep as is (lower 12 bits = 0)
    ORI  X10, X10, 0     # placeholder — lower nibbles via OR trick below

    # Build 0x12345678 another way: LUI gives [31:12], ADDI [11:0]
    # 0x12345678: upper 20 = 0x12345, lower 12 = 0x678 = 1656
    LUI  X10, 74565      # 0x12345 = 74565
    ADDI X10, X10, 0     # lower 12 = 0x678; use positive 1656

    ANDI X1, X10, 255          # byte0 = 0x78
    SRLI X2, X10, 8
    ANDI X2, X2, 255           # byte1 = 0x56
    SRLI X3, X10, 16
    ANDI X3, X3, 255           # byte2 = 0x34
    SRLI X4, X10, 24           # byte3 = 0x12

&END
    JAL  X0, @END
