# test36.aasm
# Multi-section: constants in .DATA, code in .CODE
# .DATA lays out bytes before .CODE so we know their offsets

.DATA
.4BYTE 100
.4BYTE 200
.4BYTE 300

.CODE
&MAIN
    # .DATA starts at byte 0; load the three constants
    ADDI X1, X0, 0       # base = 0
    LW   X2, 0(X1)       # X2 = 100
    LW   X3, 4(X1)       # X3 = 200
    LW   X4, 8(X1)       # X4 = 300
    ADD  X5, X2, X3
    ADD  X5, X5, X4      # X5 = 600

&END
    JAL  X0, @END
