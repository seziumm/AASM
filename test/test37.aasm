# test37.aasm
# BLTU / BGEU: distinguish signed vs unsigned comparison
# X1 = -1 = 0xFFFFFFFF (largest unsigned), X2 = 1

.CODE
&MAIN
    ADDI X1, X0, -1      # X1 = 0xFFFFFFFF
    ADDI X2, X0, 1       # X2 = 1

    # signed: X1 < X2 (because -1 < 1)
    BLT  X1, X2, @SIGNED_LT
    ADDI X3, X0, 0       # should not execute
    JAL  X0, @AFTER_SLT

&SIGNED_LT
    ADDI X3, X0, 1       # X3 = 1: signed branch taken

&AFTER_SLT
    # unsigned: X1 > X2 (0xFFFFFFFF > 1)
    BLTU X1, X2, @UNSIGNED_LT
    ADDI X4, X0, 1       # X4 = 1: unsigned branch NOT taken (correct)
    JAL  X0, @END

&UNSIGNED_LT
    ADDI X4, X0, 0       # should not execute

&END
    JAL  X0, @END        # X3=1, X4=1
