# test39.aasm
# Multiply two 16-bit halves of a word and store results
# Demonstrates SRL/SLLI to extract high/low 16 bits

.CODE
&MAIN
    LUI  X1, 1           # X1 = 0x00001000
    ADDI X1, X1, 0       # X1 = 0x1000 = 4096

    # extract low 16 bits
    ADDI X3, X0, 0
    XORI X3, X0, -1      # X3 = 0xFFFFFFFF
    SRLI X3, X3, 16      # X3 = 0x0000FFFF
    AND  X4, X1, X3      # X4 = low16(X1)

    # extract high 16 bits
    SRLI X5, X1, 16      # X5 = high16(X1)

    # X6 = low16 * 3
    ADDI X7, X0, 3
    MUL  X6, X4, X7      # X6 = 4096 * 3 = 12288

    # X8 = high16 + low16
    ADD  X8, X4, X5      # X8 = 4096 + 0 = 4096

&END
    JAL  X0, @END
