# test40.aasm
# Even/odd classification for numbers 1..8
# X3 = 1 if even, 0 if odd; result stored in memory at base+i*4

.CODE
&MAIN
    ADDI X1, X0, 512     # output base
    ADDI X2, X0, 1       # i = 1
    ADDI X9, X0, 9       # limit
    ADDI X4, X0, 1       # mask

&LOOP
    BGE  X2, X9, @END
    AND  X3, X2, X4      # X3 = i & 1
    XORI X3, X3, 1       # X3 = 1 if even, 0 if odd
    SLLI X5, X2, 2       # offset = i * 4
    ADD  X6, X1, X5      # addr = base + offset
    SW   X3, 0(X6)       # store result
    ADDI X2, X2, 1       # i++
    JAL  X0, @LOOP

&END
    JAL  X0, @END
