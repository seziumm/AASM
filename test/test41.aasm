# test41.aasm
# Running average: accumulate 8 values, divide by 8 -> X3
# X1 = base, X2 = counter, X3 = sum, X4 = current

.CODE
&MAIN
    ADDI X1, X0, 512     # base

    # store [10, 20, 30, 40, 50, 60, 70, 80]
    ADDI X9, X0, 10
    SW   X9, 0(X1)
    ADDI X9, X0, 20
    SW   X9, 4(X1)
    ADDI X9, X0, 30
    SW   X9, 8(X1)
    ADDI X9, X0, 40
    SW   X9, 12(X1)
    ADDI X9, X0, 50
    SW   X9, 16(X1)
    ADDI X9, X0, 60
    SW   X9, 20(X1)
    ADDI X9, X0, 70
    SW   X9, 24(X1)
    ADDI X9, X0, 80
    SW   X9, 28(X1)

    ADDI X2, X0, 8       # count
    ADDI X3, X0, 0       # sum = 0
    ADD  X6, X0, X1      # ptr = base

&LOOP
    LW   X4, 0(X6)
    ADD  X3, X3, X4
    ADDI X6, X6, 4
    ADDI X2, X2, -1
    BNE  X2, X0, @LOOP

    SRLI X3, X3, 3       # avg = sum / 8  (shift right 3)

&END
    JAL  X0, @END        # X3 = 45
