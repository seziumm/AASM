# test42.aasm
# Stress test: combines R, I, S, B, U, J, M type instructions
# Computes: result = ((a * b) + c) / d  with a=3,b=4,c=8,d=5 -> X10 = 4 remainder X11 = 0

.CODE
&MAIN
    ADDI X1, X0, 3       # a = 3
    ADDI X2, X0, 4       # b = 4
    ADDI X3, X0, 8       # c = 8
    ADDI X4, X0, 5       # d = 5

    MUL  X5, X1, X2      # X5 = a * b = 12
    ADD  X6, X5, X3      # X6 = 12 + 8 = 20
    DIV  X10, X6, X4     # X10 = 20 / 5 = 4
    REM  X11, X6, X4     # X11 = 20 % 5 = 0

    # store both results to memory
    ADDI X7, X0, 0
    SW   X10, 0(X7)
    SW   X11, 4(X7)

    # verify with load
    LW   X12, 0(X7)      # X12 = 4
    LW   X13, 4(X7)      # X13 = 0

    # branch if result correct
    ADDI X8, X0, 4
    BEQ  X12, X8, @OK
    ADDI X14, X0, 0      # FAIL
    JAL  X0, @END

&OK
    ADDI X14, X0, 1      # PASS

&END
    JAL  X0, @END
